{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "title": "", "type": "text",
      "options": { "mode": "markdown", "content": "## Cluster Health" }
    },
    {
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 2 },
      "title": "Node Status", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color":"red","value":null},{"color":"green","value":1}] } } }
    },
    {
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 2 },
      "title": "Pods Running", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Running\"} == 1)", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color":"green","value":null}] } } }
    },
    {
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 2 },
      "title": "Pods Pending", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Pending\"} == 1) or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color":"green","value":null},{"color":"orange","value":1}] } } }
    },
    {
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 2 },
      "title": "Pods Failed", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Failed\"} == 1) or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color":"green","value":null},{"color":"red","value":1}] } } }
    },
    {
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 2 },
      "title": "Restarts (1h)", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "sum(increase(kube_pod_container_status_restarts_total[1h]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":3},{"color":"red","value":10}] } } }
    },
    {
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 2 },
      "title": "CPU Usage", "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":70},{"color":"red","value":90}] } } }
    },
    {
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 2 },
      "title": "Memory Usage", "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":70},{"color":"red","value":90}] } } }
    },
    {
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 2 },
      "title": "Disk Usage", "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} * 100)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":70},{"color":"red","value":90}] } } }
    },
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 6 },
      "title": "", "type": "text",
      "options": { "mode": "markdown", "content": "## Node Resources" }
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "title": "CPU Usage %", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "Total", "refId": "A" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"system\"}[5m])) * 100", "legendFormat": "System", "refId": "B" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"user\"}[5m])) * 100", "legendFormat": "User", "refId": "C" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"iowait\"}[5m])) * 100", "legendFormat": "IOWait", "refId": "D" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "custom": { "fillOpacity": 10 } } }
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "title": "Memory", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes", "legendFormat": "Total", "refId": "A" },
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used", "refId": "B" },
        { "expr": "node_memory_Cached_bytes", "legendFormat": "Cached", "refId": "C" },
        { "expr": "node_memory_Buffers_bytes", "legendFormat": "Buffers", "refId": "D" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "title": "System Load", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "node_load1", "legendFormat": "1m", "refId": "A" },
        { "expr": "node_load5", "legendFormat": "5m", "refId": "B" },
        { "expr": "node_load15", "legendFormat": "15m", "refId": "C" },
        { "expr": "count(node_cpu_seconds_total{mode=\"idle\"})", "legendFormat": "CPU Cores", "refId": "D" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 5 } } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "title": "Network I/O", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|veth.*|cali.*|flannel.*|cni.*\"}[5m])) by (device)", "legendFormat": "rx {{ device }}", "refId": "A" },
        { "expr": "-sum(rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|cali.*|flannel.*|cni.*\"}[5m])) by (device)", "legendFormat": "tx {{ device }}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15 } } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "title": "Disk I/O", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(node_disk_read_bytes_total[5m])) by (device)", "legendFormat": "read {{ device }}", "refId": "A" },
        { "expr": "-sum(rate(node_disk_written_bytes_total[5m])) by (device)", "legendFormat": "write {{ device }}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15 } } }
    },
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 24 },
      "title": "", "type": "text",
      "options": { "mode": "markdown", "content": "## Workloads by Namespace" }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "title": "CPU Usage by Namespace", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{image!=\"\"}[5m])) by (namespace)", "legendFormat": "{{ namespace }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "title": "Memory Usage by Namespace", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "sum(container_memory_working_set_bytes{image!=\"\"}) by (namespace)", "legendFormat": "{{ namespace }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 34 },
      "title": "", "type": "text",
      "options": { "mode": "markdown", "content": "## Top Consumers" }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "title": "Top 10 CPU Pods", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "topk(10, sum(rate(container_cpu_usage_seconds_total{image!=\"\"}[5m])) by (namespace, pod))", "legendFormat": "{{ namespace }}/{{ pod }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "title": "Top 10 Memory Pods", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "topk(10, sum(container_memory_working_set_bytes{image!=\"\"}) by (namespace, pod))", "legendFormat": "{{ namespace }}/{{ pod }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 44 },
      "title": "", "type": "text",
      "options": { "mode": "markdown", "content": "## Container Restarts & Issues" }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
      "title": "Container Restarts (1h)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "increase(kube_pod_container_status_restarts_total[1h]) > 0", "legendFormat": "{{ namespace }}/{{ pod }}/{{ container }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
      "title": "Pods Not Ready", "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "kube_pod_status_ready{condition=\"false\"} == 1", "refId": "A", "format": "table", "instant": true }],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["namespace", "pod", "Value"] } } }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [{ "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.hidden", "value": true }] }] }
    },
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 54 },
      "title": "", "type": "text",
      "options": { "mode": "markdown", "content": "## Persistent Volumes" }
    },
    {
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 56 },
      "title": "PVC Usage", "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "kubelet_volume_stats_used_bytes", "refId": "A", "format": "table", "instant": true },
        { "expr": "kubelet_volume_stats_capacity_bytes", "refId": "B", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["namespace", "persistentvolumeclaim", "Value #A", "Value #B"] } } },
        { "id": "organize", "options": { "renameByName": { "Value #A": "Used", "Value #B": "Capacity" } } }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ],
  "schemaVersion": 39,
  "templating": {
    "list": [{
      "name": "datasource",
      "type": "datasource",
      "query": "prometheus",
      "current": { "text": "Mimir", "value": "Mimir" }
    }]
  },
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "title": "K8s Operations",
  "uid": "k8s-ops"
}
