# =============================================================================
# K8s DevOps Stack — Netzwerk- und Umgebungskonfiguration
# =============================================================================
# Diese Datei wird von bootstrap.sh und stack.sh gelesen.
# Anpassen fuer andere Deployments / Netzwerke.
# =============================================================================

# --- Architektur -------------------------------------------------------------
# Ziel-Architektur fuer Container Images (arm64 oder amd64)
# Bestimmt den Tag-Suffix: image:tag-${ARCH} (z.B. openbao:2.5.1-arm64)
ARCH="arm64"

# --- Lima VM -----------------------------------------------------------------
LIMA_VM_NAME="k3s-server"
LIMA_CPUS=8
LIMA_MEMORY_GB=48
LIMA_DISK_GB=200

# --- Netzwerk ----------------------------------------------------------------
# vzNAT-Subnetz (von macOS Virtualization.framework vergeben)
NETWORK_SUBNET="192.168.64.0/24"
NETWORK_GATEWAY="192.168.64.1"
NETWORK_DNS="192.168.64.1"

# MetalLB IP-Pool (muss im vzNAT-Subnetz liegen, oberer Bereich)
METALLB_IP_RANGE="192.168.64.200-192.168.64.210"

# --- Domains -----------------------------------------------------------------
# Platform & Management Services
PLATFORM_DOMAIN="development.cfapps.cool"
# Application Workloads
APPS_DOMAIN="app.cfapps.cool"

# --- Container Registry ------------------------------------------------------
REGISTRY="artifactory.cfapps.cool"
REGISTRY_REPO="docker-local"
REGISTRY_PULL_SECRET_NAME="artifact-keeper-pull"

# --- TLS / cert-manager ------------------------------------------------------
ACME_EMAIL="admin@cfapps.cool"
# GCP Projekt-ID fuer Cloud DNS (DNS-01 Challenge)
GCP_PROJECT_ID="cfapps-cool"
# DNS-Zonen die via Cloud DNS validiert werden
ACME_DNS_ZONES_CLOUDDNS="cfapps.cool"
# DNS-Zonen die via Route53 validiert werden (leer = nicht verwendet)
ACME_DNS_ZONES_ROUTE53=""

# --- Persistent Storage ------------------------------------------------------
PV_BASE_PATH="/data/persistent"
